# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` to GitHub.

# MySQL
# Set a strong password in your local `.env` (or via your container orchestration).
MYSQL_ROOT_PASSWORD=change_me

# Spring datasource (services read these)
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change_me

# JWT (shared by services)
# Replace with a long random secret in your local `.env` (keep private).
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRATION_MILLIS=86400000

# CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Eureka
EUREKA_SERVER_URL=http://discovery-server:8761/eureka/
# Set to false if you're deploying a service without a running discovery-server.
EUREKA_CLIENT_ENABLED=true

# OAuth (only needed if you enable oauth profile)
SPRING_PROFILES_ACTIVE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google
OAUTH2_SUCCESS_REDIRECT=http://localhost:5173/oauth-success
